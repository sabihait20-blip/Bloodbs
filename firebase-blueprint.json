{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user account",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isVerified": { "type": "boolean" },
        "points": { "type": "number" },
        "badges": { "type": "array" }
      },
      "required": ["uid", "name", "email"]
    },
    "Donor": {
      "title": "Donor",
      "description": "Blood donor profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "lastDonated": { "type": "string" },
        "image": { "type": "string" },
        "available": { "type": "boolean" },
        "facebookUrl": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "donationCount": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "points": { "type": "number" },
        "badges": { "type": "array" }
      },
      "required": ["id", "userId", "name", "bloodGroup", "location", "phone"]
    },
    "Request": {
      "title": "Blood Request",
      "description": "Urgent blood request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "requesterName": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "requesterName", "bloodGroup", "location", "phone", "status"]
    },
    "Hospital": {
      "title": "Hospital",
      "description": "Blood bank or hospital",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "phone": { "type": "string" },
        "type": { "type": "string", "enum": ["hospital", "blood_bank"] }
      },
      "required": ["id", "name", "location", "phone", "type"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/donors/{donorId}": {
      "schema": "Donor",
      "description": "Donor profiles"
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "Blood requests"
    },
    "/hospitals/{hospitalId}": {
      "schema": "Hospital",
      "description": "Blood banks and hospitals"
    }
  }
}
